<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('./partials/head.ejs') %>
    <title>Home | BłogTyy</title>
  </head>
  <body class="bg-light">
    <%- include('./nav.ejs') %> 

    <div class="container mt-5 mb-5">
      
      <!-- Page Header -->
      <div class="row mb-4">
        <div class="col">
          <h1 class="fw-bold">Latest Blogs</h1>
          <p class="text-muted">Discover the newest stories, thinking, and expertise.</p>
        </div>
      </div>

      <!-- Blog Grid -->
      <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        
        <!-- Check if there are any blogs in the database -->
        <% if (locals.blogs && blogs.length > 0) { %>
          
          <!-- Loop through each blog -->
          <% blogs.forEach(blog => { %>
            <div class="col">
              <div class="card h-100 shadow-sm border-0 rounded-3 overflow-hidden">
                
                <!-- Display Cover Image -->
                <% if (blog.coverImgUrl) { %>
                  <img src="<%= blog.coverImgUrl %>" class="card-img-top" alt="<%= blog.title %>" style="height: 220px; object-fit: cover;">
                <% } else { %>
                  <!-- Fallback gray box if they didn't upload an image -->
                  <div class="bg-secondary bg-opacity-25 d-flex align-items-center justify-content-center" style="height: 220px;">
                    <span class="text-muted">No Image</span>
                  </div>
                <% } %>
                
                <div class="card-body d-flex flex-column p-4">
                  <h5 class="card-title fw-bold text-dark"><%= blog.title %></h5>
                  
                  <!-- Show just the first 100 characters of the blog body -->
                  <p class="card-text text-muted mb-4" style="line-height: 1.6;">
                    <%= blog.body.substring(0, 100) %>...
                  </p>
                  
                  <!-- Read More Button (Pushed to the bottom using mt-auto) -->
                  <a href="/blog/<%= blog._id %>" class="btn btn-outline-dark mt-auto w-100 fw-semibold">Read More</a>
                </div>
                
              </div>
            </div>
          <% }) %>

        <% } else { %>
          <!-- What to show if the database is empty -->
          <div class="col-12">
            <div class="alert alert-light border shadow-sm p-5 text-center" role="alert">
              <h4 class="alert-heading fw-bold mb-3">No blogs found!</h4>
              <p class="mb-0 text-muted">It's a little quiet here. Be the first to <a href="/blog/add-new" class="text-primary text-decoration-none fw-bold">publish a blog post</a>.</p>
            </div>
          </div>
        <% } %>

      </div>
    </div>

    <%- include('./partials/script.ejs') %>
  </body>
</html>